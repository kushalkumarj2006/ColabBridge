# -------------------- AUTHENTICATION --------------------
# API Secret for authenticating requests
API_SECRET=your-secret-key

# Google Colab Authentication Token
# Get it from: cat ~/.config/colab-cli/token.json
# Copy entire JSON content as single line
COLAB_AUTH_TOKEN='{"token": "ya29.a0AT...........mKcA0206", "refresh_token": "1//0g4sU.............vhxoCU5Xs", "token_uri": "https://oauth2.googleapis.com/token", "client_id": "764086............di341hur.apps.googleusercontent.com", "client_secret": "d-FL9...........HD0Ty", "scopes": ["openid", "https://www.googleapis.com/auth/userinfo.profile", "https://www.googleapis.com/auth/userinfo.email", "https://www.googleapis.com/auth/cloud-platform", "https://www.googleapis.com/auth/colaboratory", "https://www.googleapis.com/auth/drive.file"], "universe_domain": "googleapis.com", "account": "", "expiry": "2026-06-16T10:40:31.096124Z"}'

# Refresh data (extracted from token.json)
COLAB_REFRESH_DATA='{"refresh_token":"1//0g4sUFm..............hxoCU5Xs","client_id":"764086.............di341hur.apps.googleusercontent.com","client_secret":"d-FL9........D0Ty","token_uri":"https://oauth2.googleapis.com/token"}'

# -------------------- SERVER --------------------
PORT=3000
NODE_ENV=development
LOG_LEVEL=info
DEBUG_ENABLED=true

# -------------------- SESSIONS --------------------
MAX_SESSIONS=2
SESSION_TIMEOUT=10800000  # 3 hours
SESSIONS_BASE_DIR=/tmp/colab_sessions
PERSIST_SESSION_DATA=true
CLEANUP_INTERVAL=3600000  # 1 hour

# -------------------- EXECUTION --------------------
EXECUTION_TIMEOUT=7200  # 2 hours
MAX_CODE_SIZE=3145728  # 3 MB
MAX_CODE_LENGTH=100000
MAX_RETRY_ATTEMPTS=3
STREAMING_ENABLED=true

# -------------------- OTHER --------------------
COMPLETED_EXECUTIONS_TTL=600000  # 10 minutes
POLL_INTERVAL=15000
HEALTH_CHECK_INTERVAL=30000
HANGING_PROCESS_CLEANUP_INTERVAL=300000  # 5 minutes

# ============================================
# INSTALLATION & COMMANDS
# ============================================
# INSTALLATION:
# > pip3 install google-colab-cli
# NOTE: google-colab-cli supports Linux and Mac only (not Windows)
# 
# AUTHENTICATION:
# > colab sessions  # Opens browser for OAuth
# 
# GET TOKEN:
# > cat ~/.config/colab-cli/token.json
# 
# COPY TOKEN:
# > cp ~/.config/colab-cli/token.json ./token.json
# 
# CHECK VERSION:
# > colab version
# 
# LIST SESSIONS:
# > colab sessions
# 
# CREATE SESSION:
# > colab new --gpu T4 -s SESSION_NAME
# 
# STOP SESSION:
# > colab stop -s SESSION_NAME
# > colab stop  # Stop all sessions
# 
# EXECUTE CODE:
# > echo "print('Hello')" | colab exec -s SESSION_NAME
